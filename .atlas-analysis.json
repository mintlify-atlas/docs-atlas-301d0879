  "keyFeatures": [
    "Auth0 authentication for Next.js (App Router & Pages Router)",
    "Server-side and client-side session management",
    "React hooks (useUser, getAccessToken)",
    "DPoP (Demonstrating Proof-of-Possession) support",
    "Multi-Resource Refresh Tokens (MRRT)",
    "Multi-Factor Authentication (MFA)",
    "Stateless and stateful session stores",
    "My Account and My Organization API proxy handlers"
  ],
  "publicApiSurface": [
    "@auth0/nextjs-auth0 - useUser, getAccessToken, Auth0Provider, withPageAuthRequired",
    "@auth0/nextjs-auth0/server - Auth0Client, AbstractSessionStore, TransactionStore",
    "@auth0/nextjs-auth0/errors - SdkError, OAuth2Error, AccessTokenError, MfaRequiredError, DPoPError",
    "@auth0/nextjs-auth0/types - SessionData, User, TokenSet, AuthorizationParameters",
    "@auth0/nextjs-auth0/testing - generateSessionCookie",
    "Auth0Client methods: middleware, getSession, getAccessToken, updateSession, createFetcher",
    "Authentication routes: /auth/login, /auth/logout, /auth/callback, /auth/profile, /auth/access-token"
